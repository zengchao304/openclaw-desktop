{
  "name": "openclaw-desktop",
  "version": "0.4.3+openclaw.2026.3.24",
  "openclawBundleVersion": "2026.3.24",
  "description": "Community-maintained Windows desktop app and installer for OpenClaw.",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "i18n:zh-tw": "node scripts/generate-zh-tw.mjs",
    "download-node": "tsx scripts/download-node.ts",
    "download-openclaw": "tsx scripts/download-openclaw.ts",
    "package:prepare-deps": "pnpm run download-node && pnpm run download-openclaw",
    "prepare-bundle": "tsx scripts/prepare-bundle.ts",
    "check-openclaw-versions": "tsx scripts/check-openclaw-versions.ts",
    "verify-resource-versions": "tsx scripts/check-openclaw-versions.ts",
    "verify-bundle": "tsx scripts/verify-bundle.ts",
    "verify-packaged-win": "tsx scripts/verify-packaged-win.ts",
    "verify-native-modules": "tsx scripts/verify-native-modules.ts",
    "clean-resources": "tsx scripts/clean-resources.ts",
    "clean-build": "tsx scripts/clean-build.ts",
    "clean-all": "pnpm run clean-build && pnpm run clean-resources",
    "generate-resources": "node scripts/generate-resources.mjs",
    "smoke:csp": "tsx scripts/smoke/gateway-response-headers-smoke.ts",
    "smoke:gateway": "electron scripts/smoke/process-manager-electron-runner.cjs",
    "smoke": "npm run smoke:csp && npm run smoke:gateway",
    "package:win": "pnpm run build && pnpm run clean-resources && pnpm run check-openclaw-versions -- --pre-pack && pnpm run verify-bundle && cross-env REGENERATE_ICON=1 pnpm run generate-resources && pnpm run prepare-bundle && pnpm run check-openclaw-versions && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false SKIP_EXE_RESOURCE_EDIT=0 ELECTRON_BUILDER_BINARIES_MIRROR=https://registry.npmmirror.com/-/binary/electron-builder-binaries/ pnpm exec electron-builder --win --x64 --config electron-builder.config.cjs --publish never && pnpm run verify-packaged-win",
    "package:win:signed": "node scripts/package-win-signed.mjs",
    "generate-dev-cert": "node scripts/generate-dev-cert.mjs",
    "export-dev-cert-for-ci": "node scripts/export-dev-cert-for-ci.mjs"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "i18next": "^24.2.0",
    "json5": "^2.2.3",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.1.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^2.1.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "adm-zip": "^0.5.16",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "opencc-js": "^1.0.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "to-ico": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.56.1",
    "xlsx": "^0.18.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "sharp"
    ]
  },
  "keywords": [
    "openclaw",
    "openclaw-desktop",
    "openclaw-windows",
    "openclaw-installer",
    "electron",
    "windows",
    "ai-agent"
  ],
  "homepage": "https://github.com/agentkernel/openclaw-desktop",
  "author": "wurongzhao@AgentKernel",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentkernel/openclaw-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/agentkernel/openclaw-desktop/issues"
  },
  "license": "GPL-3.0",
  "engines": {
    "node": ">=22.16.0"
  }
}
